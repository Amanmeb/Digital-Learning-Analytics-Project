# .env.example
# CDLAID Analytics Platform
# Copy this file to .env and fill in all values
# Never commit .env to GitHub -- only .env.example

# ─────────────────────────────────────────────
# PostgreSQL -- Central server data warehouse
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cdlaid_analytics
DB_USER=cdlaid_user
DB_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://cdlaid_user:your_strong_password_here@localhost:5432/cdlaid_analytics

# ─────────────────────────────────────────────
# API Security
# ─────────────────────────────────────────────
API_SECRET_KEY=replace_with_64_character_random_string
API_KEY_HEADER=X-API-Key

# ─────────────────────────────────────────────
# LRS -- Learning Record Store
# Configured at Step 6 -- leave placeholders until then
# ─────────────────────────────────────────────
LRS_ENDPOINT=http://localhost:8081/xapi
LRS_KEY=replace_after_lrs_setup
LRS_SECRET=replace_after_lrs_setup

# ─────────────────────────────────────────────
# Apache Superset
# ─────────────────────────────────────────────
SUPERSET_SECRET_KEY=replace_with_64_character_random_string
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=your_strong_password_here

# ─────────────────────────────────────────────
# Moodle and MySQL -- School server LMS
# ─────────────────────────────────────────────
MOODLE_DB_HOST=localhost
MOODLE_DB_PORT=3306
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle_user
MOODLE_DB_PASSWORD=your_strong_password_here

# ─────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────
ENVIRONMENT=development
DEMO_MODE=false

# ─────────────────────────────────────────────
# Server and School Identity
# Format: SRV-[COUNTRY]-[REGION]-[SCHOOL_SEQUENCE]-[SERVER_SEQUENCE]
# Example: SRV-ET-AA-001-001
# ─────────────────────────────────────────────
SERVER_ID=SRV-ET-AA-001-001
SCHOOL_ID=ET-AA-001

# ─────────────────────────────────────────────
# xAPI Emitter Settings
# XAPI_HOMEPAGE_URL -- set to your country domain
# No hardcoded production URL -- each country sets their own
# Example Ethiopia: https://learn.camara.et
# Example Kenya:    https://learn.camara.ke
# ─────────────────────────────────────────────
XAPI_HOMEPAGE_URL=https://your-country-domain-here
QUEUE_DB_PATH=edge/queue.db
XAPI_SERVER_ID=SRV-ET-AA-001-001
XAPI_SCHOOL_ID=ET-AA-001

# ─────────────────────────────────────────────
# Sync Agent -- Edge settings
# These are environment variables not stored in ops.settings
# ─────────────────────────────────────────────
BACKLOG_ALERT_LOW=3
BACKLOG_ALERT_MID=7
BACKLOG_ALERT_HIGH=15
SYNC_BATCH_SIZE=500